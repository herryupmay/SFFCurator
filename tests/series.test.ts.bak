/**
 * Tests for series collapse — turning multi-volume series listings
 * (Sandman 1, Sandman 2, ..., Sandman 1~7 box set) into a single Work.
 *
 * Driven by the 2026-05-05 curation report: 10 of 26 results were Sandman
 * volumes. The user asked for one card per series with all source URLs
 * aggregated.
 */

import { describe, test, expect } from 'bun:test';
import { seriesKey, collapseSeries } from '../src/core/matching';
import type { Work } from '../src/types';

function w(overrides: Partial<Work> & { sources: Work['sources']; titles: Work['titles'] }): Work {
  return {
    creators: [{ name: { en: 'Author X' }, role: 'author' }],
    medium: 'book',
    raw: {},
    confidence: 'low',
    ...overrides,
  };
}

describe('seriesKey', () => {
  test('strips trailing volume numbers (single)', () => {
    expect(seriesKey('睡魔1')).toBe('睡魔');
    expect(seriesKey('睡魔 8')).toBe('睡魔');
    expect(seriesKey('Sandman 1')).toBe('Sandman');
  });

  test('strips volume ranges (1~7, 1-7, 1–7)', () => {
    expect(seriesKey('睡魔1~7套書')).toBe('睡魔');
    expect(seriesKey('睡魔1-7')).toBe('睡魔');
    expect(seriesKey('睡魔1–7')).toBe('睡魔');
  });

  test('strips marketing brackets 【...】', () => {
    expect(seriesKey('睡魔1【全球Netflix TOP 1 人氣影集同名原作】')).toBe('睡魔');
  });

  test('strips parenthesized edition notes (zh + ASCII)', () => {
    expect(seriesKey('睡魔1（三十周年典藏封面紀念版）')).toBe('睡魔');
    expect(seriesKey('睡魔1(三十周年典藏封面紀念版)')).toBe('睡魔');
    expect(seriesKey('OPUS地球計畫 2(完)')).toBe('OPUS地球計畫');
  });

  test('strips colon subtitle (everything after ：or :)', () => {
    expect(seriesKey('睡魔1：前奏與夜曲')).toBe('睡魔');
    expect(seriesKey('Sandman: Preludes and Nocturnes')).toBe('Sandman');
    expect(seriesKey('Rick and Morty: The Manga Vol. 2')).toBe('Rick and Morty');
  });

  test('strips english Vol.X / Volume X markers', () => {
    expect(seriesKey('Berserk Vol. 1')).toBe('Berserk');
    expect(seriesKey('Berserk Volume 41')).toBe('Berserk');
    expect(seriesKey('Lone Wolf and Cub vol. 1-3')).toBe('Lone Wolf and Cub');
  });

  test('handles compound stripping: brackets + parens + colon + vol number', () => {
    // The full Sandman vol-1 title from the real curation report.
    expect(
      seriesKey('睡魔1：前奏與夜曲(三十周年典藏封面紀念版)【全球Netflix TOP 1 人氣影集同名原作，奇幻文學大師尼爾‧蓋曼最知名經典美漫代表作，首集Netflix影視書衣版】')
    ).toBe('睡魔');
  });

  test('does NOT strip when there is no marker (idempotent on bare titles)', () => {
    expect(seriesKey('Neuromancer')).toBe('Neuromancer');
    expect(seriesKey('地下街的透明少女')).toBe('地下街的透明少女');
  });

  test('strips standalone trailing vol-words (上/下/完/套書)', () => {
    expect(seriesKey('銀河英雄傳説 上')).toBe('銀河英雄傳説');
    expect(seriesKey('銀河英雄傳説 套書')).toBe('銀河英雄傳説');
  });

  test('returns empty string for empty input', () => {
    expect(seriesKey('')).toBe('');
  });
});

describe('collapseSeries', () => {
  test('collapses 7 Sandman main-series volumes into one work', () => {
    const sandman = (volTitle: string, url: string) => w({
      sources: { books_tw: url },
      titles: { zh: volTitle },
      creators: [{ name: { zh: '尼爾．蓋曼（Neil Gaiman）' }, role: 'author' }],
      medium: 'book',
    });
    const works = [
      sandman('睡魔1：前奏與夜曲(三十周年典藏封面紀念版)', '/products/0011023903'),
      sandman('睡魔2：玩偶之家(三十周年典藏封面紀念版)', '/products/0011027606'),
      sandman('睡魔3：夢之國度(三十周年典藏封面紀念版)', '/products/0011027607'),
      sandman('睡魔6：寓言與倒影(三十周年典藏封面紀念版)', '/products/0011032407'),
      sandman('睡魔7：浮生若寄(三十周年典藏封面紀念版)', '/products/0011032408'),
      sandman('睡魔8：世界盡頭(三十周年典藏封面紀念版)', '/products/0011037425'),
      sandman('睡魔1~7套書(三十周年限量典藏封面紀念書盒版)', '/products/0011023885'),
    ];

    const out = collapseSeries(works);
    expect(out.length).toBe(1);
    expect(out[0].titles.zh ?? '').toBe('睡魔 (全 7 冊)');
    // All 7 URLs survive — collisions are suffixed (books_tw, books_tw_2,
    // books_tw_3, ...). Without this the user loses 6 click-throughs.
    expect(Object.keys(out[0].sources).length).toBe(7);
    expect(out[0].sources.books_tw).toBeDefined();
    expect(out[0].sources.books_tw_2).toBeDefined();
    expect(out[0].sources.books_tw_7).toBeDefined();
    // Confidence got bumped because we now have 7 sources.
    expect(['medium', 'high']).toContain(out[0].confidence ?? '');
  });

  test('does NOT collapse the 睡魔特典 (special edition) into 睡魔 — different prefix', () => {
    const w1 = w({
      sources: { books_tw: 'a' },
      titles: { zh: '睡魔1：前奏與夜曲' },
      creators: [{ name: { zh: '尼爾．蓋曼' }, role: 'author' }],
    });
    const w2 = w({
      sources: { books_tw: 'b' },
      titles: { zh: '睡魔特典二：狩夢' },
      creators: [{ name: { zh: '尼爾．蓋曼' }, role: 'author' }],
    });
    const out = collapseSeries([w1, w2]);
    // Different series keys (睡魔 vs 睡魔特典) → not collapsed.
    expect(out.length).toBe(2);
  });

  test('collapses 睡魔特典 1+2+3 into one work', () => {
    const sp = (vol: string, url: string) => w({
      sources: { books_tw: url },
      titles: { zh: `睡魔特典${vol}：dummy` },
      creators: [{ name: { zh: '尼爾．蓋曼' }, role: 'author' }],
    });
    const works = [sp('一', '1'), sp('二', '2'), sp('三', '3')];
    // Note: the chinese vol numbers (一/二/三) aren't matched by the digit
    // regex, so each title's seriesKey ends up "睡魔特典X" where X varies.
    // This documents current behaviour; if we want to also strip Chinese
    // numerals, we can extend seriesKey() later.
    const out = collapseSeries(works);
    // For now: not collapsed because Chinese numerals aren't stripped.
    expect(out.length).toBe(3);
  });

  test('does NOT collapse works by different authors with matching prefix', () => {
    const w1 = w({
      sources: { books_tw: 'a' },
      titles: { zh: '太空1' },
      creators: [{ name: { en: 'Author A' }, role: 'author' }],
    });
    const w2 = w({
      sources: { books_tw: 'b' },
      titles: { zh: '太空2' },
      creators: [{ name: { en: 'Author B' }, role: 'author' }],
    });
    const out = collapseSeries([w1, w2]);
    expect(out.length).toBe(2);
  });

  test('does NOT collapse works in different mediums', () => {
    const w1 = w({
      sources: { anilist: 'a' },
      titles: { en: 'Berserk Vol. 1' },
      creators: [{ name: { en: 'Kentaro Miura' }, role: 'author' }],
      medium: 'manga',
    });
    const w2 = w({
      sources: { anilist: 'b' },
      titles: { en: 'Berserk Vol. 1' },
      creators: [{ name: { en: 'Kentaro Miura' }, role: 'author' }],
      medium: 'anime',
    });
    const out = collapseSeries([w1, w2]);
    expect(out.length).toBe(2);
  });

  test('singletons pass through untouched', () => {
    const w1 = w({
      sources: { isfdb: 'a' },
      titles: { en: 'Neuromancer' },
      creators: [{ name: { en: 'William Gibson' }, role: 'author' }],
    });
    const out = collapseSeries([w1]);
    expect(out.length).toBe(1);
    expect(out[0].titles.en).toBe('Neuromancer');
  });

  test('OPUS地球計畫 1 + 2 + 1-2 boxset collapse into one', () => {
    const opus = (vol: string, url: string) => w({
      sources: { books_tw: url },
      titles: { zh: `OPUS地球計畫 ${vol}` },
      creators: [{ name: { zh: 'SIGONO' }, role: 'author' }],
    });
    const works = [opus('1', '1'), opus('2(完)', '2'), opus('1-2(完)', '12')];
    const out = collapseSeries(works);
    expect(out.length).toBe(1);
    expect(out[0].titles.zh ?? '').toBe('OPUS地球計畫 (全 3 冊)');
  });

  test('works without title or without author bypass collapse', () => {
    const w1 = w({
      sources: { isfdb: 'a' },
      titles: {},
      creators: [{ name: { en: 'X' }, role: 'author' }],
    });
    const w2 = w({
      sources: { isfdb: 'b' },
      titles: { en: 'Foo 1' },
      creators: [],
    });
    const out = collapseSeries([w1, w2]);
    // Both fall through to standalone (no title / no author).
    expect(out.length).toBe(2);
  });

  test('series key too short (1 char) bypasses collapse', () => {
    // After stripping, "X1" → "X" which is 1 char → not a series key.
    const w1 = w({
      sources: { isfdb: 'a' },
      titles: { en: 'X1' },
      creators: [{ name: { en: 'Author' }, role: 'author' }],
    });
    const w2 = w({
    const w2 = w({
      sources: { isfdb: 'b' },
      titles: { en: 'X2' },
      creators: [{ name: { en: 'Author' }, role: 'author' }],
    });
    const out = collapseSeries([w1, w2]);
    expect(out.length).toBe(2);
  });
});
